#!/usr/bin/env python3
"""Calculate XP reward for defeated enemies (D&D 5e).

Usage:
  ./calc-xp 1/4 1/4          # Two CR 1/4 enemies
  ./calc-xp 1/2               # One CR 1/2 enemy
  ./calc-xp 1 0.5 0.25        # Mixed CRs

Accepts CR as fractions (1/4, 1/8) or decimals (0.25, 0.125).
"""

import sys

# XP by CR from the DMG
XP_TABLE = {
    0:     10,
    0.125: 25,
    0.25:  50,
    0.5:   100,
    1:     200,
    2:     450,
    3:     700,
    4:     1100,
    5:     1800,
    6:     2300,
    7:     2900,
    8:     3900,
    9:     5000,
    10:    5900,
}

# Level-up thresholds
LEVEL_THRESHOLDS = {
    1: 0,
    2: 300,
    3: 900,
    4: 2700,
    5: 6500,
    6: 14000,
    7: 23000,
    8: 34000,
    9: 48000,
    10: 64000,
}


def parse_cr(cr_str):
    """Parse CR string like '1/4', '0', '2' into a float."""
    cr_str = cr_str.strip()
    if "/" in cr_str:
        num, den = cr_str.split("/")
        return int(num) / int(den)
    return float(cr_str)


def format_cr(cr):
    """Format CR float back to readable string."""
    if cr == 0.125:
        return "1/8"
    if cr == 0.25:
        return "1/4"
    if cr == 0.5:
        return "1/2"
    if cr == int(cr):
        return str(int(cr))
    return str(cr)


def main():
    args = sys.argv[1:]

    if not args or "--help" in args or "-h" in args:
        print(__doc__)
        sys.exit(0)

    # Parse optional --level and --current-xp for progress tracking
    level = None
    current_xp = None
    cr_args = []

    i = 0
    while i < len(args):
        if args[i] == "--level":
            level = int(args[i + 1])
            i += 2
        elif args[i] == "--current-xp":
            current_xp = int(args[i + 1])
            i += 2
        else:
            cr_args.append(args[i])
            i += 1

    if not cr_args:
        print("ERROR: Provide at least one CR value")
        sys.exit(1)

    crs = []
    for arg in cr_args:
        cr = parse_cr(arg)
        if cr not in XP_TABLE:
            print(f"ERROR: CR {format_cr(cr)} not in XP table (range: 0 to 10)")
            sys.exit(1)
        crs.append(cr)

    # Calculate XP
    total = 0
    for cr in crs:
        xp = XP_TABLE[cr]
        print(f"  CR {format_cr(cr):>4s} = {xp} XP")
        total += xp

    print(f"  {'':>4s}   ------")
    print(f"  Total = {total} XP")

    # Show progress if level info provided
    if level is not None and current_xp is not None:
        new_xp = current_xp + total
        next_level = level + 1
        if next_level in LEVEL_THRESHOLDS:
            threshold = LEVEL_THRESHOLDS[next_level]
            remaining = threshold - new_xp
            print()
            print(f"  XP: {current_xp} + {total} = {new_xp}")
            if remaining <= 0:
                print(f"  LEVEL UP! Reached {threshold} XP for level {next_level}!")
            else:
                print(f"  Need {remaining} more XP for level {next_level} ({threshold})")


if __name__ == "__main__":
    main()
