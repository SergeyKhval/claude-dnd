COMMANDS = {
    "monster": cmd_monster,
    "spell": cmd_spell,
    "equipment": cmd_equipment,
    "condition": cmd_condition,
    "magic-item": cmd_magic_item,
}


def main():
    args = sys.argv[1:]

    if not args or "--help" in args or "-h" in args:
        print(__doc__)
        sys.exit(0)

    cmd = args[0].lower()
    if cmd not in COMMANDS:
        print(f"Unknown resource: {cmd}")
        print(f"Available: {', '.join(COMMANDS.keys())}")
        sys.exit(1)

    COMMANDS[cmd](args[1:])


if __name__ == "__main__":
    main()
